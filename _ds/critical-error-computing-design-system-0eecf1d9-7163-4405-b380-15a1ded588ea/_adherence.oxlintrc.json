{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/feedback/**",
              "components/fleet/**",
              "components/forms/**",
              "components/surfaces/**",
              "ui_kits/storefront/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:IBM Plex Mono|Saira|Saira Condensed))/i]",
        "message": "Font not provided by the design system. Available: IBM Plex Mono, Saira, Saira Condensed."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|size|repCue|icon|iconRight|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: variant, size, repCue, icon, iconRight."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|ghost)$/]",
        "message": "<Button> variant must be one of 'primary' | 'ghost'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:md|sm)$/]",
        "message": "<Button> size must be one of 'md' | 'sm'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:hover|featured|pad|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: hover, featured, pad."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute > JSXIdentifier[name!=/^(?:dot|status|key|ref|className|style|children)$/]",
        "message": "<Chip> doesn't accept that prop. Declared props: dot, status."
      },
      {
        "selector": "JSXOpeningElement[name.name='Chip'] > JSXAttribute[name.name='status'] > Literal[value!=/^(?:ok|warn|accent)$/]",
        "message": "<Chip> status must be one of 'ok' | 'warn' | 'accent'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Eyebrow'] > JSXAttribute > JSXIdentifier[name!=/^(?:rule|key|ref|className|style|children)$/]",
        "message": "<Eyebrow> doesn't accept that prop. Declared props: rule."
      },
      {
        "selector": "JSXOpeningElement[name.name='Field'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|style|inputStyle|key|ref|className|style|children)$/]",
        "message": "<Field> doesn't accept that prop. Declared props: label, style, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='FleetCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:no|name|price|priceNote|img|role|tier|chips|href|featured|flag|accent|key|ref|className|style|children)$/]",
        "message": "<FleetCard> doesn't accept that prop. Declared props: no, name, price, priceNote, img, role, tier, chips, href, featured, flag, accent."
      },
      {
        "selector": "JSXOpeningElement[name.name='GlitchText'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|alt|accent|every|key|ref|className|style|children)$/]",
        "message": "<GlitchText> doesn't accept that prop. Declared props: children, alt, accent, every."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProbeBubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:who|stamp|avatar|key|ref|className|style|children)$/]",
        "message": "<ProbeBubble> doesn't accept that prop. Declared props: who, stamp, avatar."
      },
      {
        "selector": "JSXOpeningElement[name.name='ProbeBubble'] > JSXAttribute[name.name='who'] > Literal[value!=/^(?:bot|user)$/]",
        "message": "<ProbeBubble> who must be one of 'bot' | 'user'."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|key|ref|className|style|children)$/]",
        "message": "<SegControl> doesn't accept that prop. Declared props: options, value, onChange."
      },
      {
        "selector": "JSXOpeningElement[name.name='SpecTable'] > JSXAttribute > JSXIdentifier[name!=/^(?:specs|rows|litKey|key|ref|className|style|children)$/]",
        "message": "<SpecTable> doesn't accept that prop. Declared props: specs, rows, litKey."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute > JSXIdentifier[name!=/^(?:variant|key|ref|className|style|children)$/]",
        "message": "<Tag> doesn't accept that prop. Declared props: variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Tag'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:flag|outline)$/]",
        "message": "<Tag> variant must be one of 'flag' | 'outline'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
